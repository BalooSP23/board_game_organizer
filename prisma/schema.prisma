generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id             String    @id @default(cuid())
  bggId          Int?      @unique
  name           String
  description    String?   @db.Text
  thumbnailUrl   String?
  imageUrl       String?
  minPlayers     Int?
  maxPlayers     Int?
  playingTime    Int?
  minPlayingTime Int?
  yearPublished  Int?
  rating         Float?
  weight         Float?
  categories     Json?
  mechanics      Json?

  // Box dimensions (cm)
  boxWidth  Float?
  boxHeight Float?
  boxDepth  Float?

  // Purchase info
  purchasePrice  Float?
  purchaseDate   DateTime?
  notes          String?   @db.Text

  // AI summary
  aiSummary            String?   @db.Text
  aiSummaryGeneratedAt DateTime?

  // Wishlist
  isWishlisted   Boolean   @default(false)
  wishlistShopUrl String?

  // Extension self-relation
  parentGameId     String?
  parentGame       Game?    @relation("GameExtensions", fields: [parentGameId], references: [id])
  extensions       Game[]   @relation("GameExtensions")
  fitsInParentBox  Boolean  @default(false)

  // Relations
  images     Image[]
  loans      Loan[]
  placements GamePlacement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([isWishlisted])
  @@index([parentGameId])
}

model Image {
  id                String @id @default(cuid())
  gameId            String
  game              Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  url               String
  cloudinaryPublicId String?
  caption           String?
  sortOrder         Int    @default(0)

  createdAt DateTime @default(now())

  @@index([gameId])
}

model Loan {
  id           String    @id @default(cuid())
  gameId       String
  game         Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  borrowerName String
  loanDate     DateTime  @default(now())
  returnDate   DateTime?
  notes        String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameId])
  @@index([borrowerName])
}

model Furniture {
  id        String          @id @default(cuid())
  name      String
  rows      Int
  cols      Int
  cells     FurnitureCell[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model FurnitureCell {
  id          String      @id @default(cuid())
  furnitureId String
  furniture   Furniture   @relation(fields: [furnitureId], references: [id], onDelete: Cascade)
  row         Int
  col         Int
  hasLaxRax   Boolean     @default(false)
  shelves     CellShelf[]
  placements  GamePlacement[]

  @@unique([furnitureId, row, col])
  @@index([furnitureId])
}

model CellShelf {
  id         String        @id @default(cuid())
  cellId     String
  cell       FurnitureCell @relation(fields: [cellId], references: [id], onDelete: Cascade)
  position   Int
  heightCm   Float
  spacingMm  Int           @default(0)
  placements GamePlacement[]

  @@index([cellId])
}

model GamePlacement {
  id          String         @id @default(cuid())
  gameId      String
  game        Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  cellId      String
  cell        FurnitureCell  @relation(fields: [cellId], references: [id], onDelete: Cascade)
  shelfId     String?
  shelf       CellShelf?     @relation(fields: [shelfId], references: [id], onDelete: SetNull)
  position    Int            @default(0)
  orientation String         @default("front") // front | side | stacked

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([gameId])
  @@index([cellId])
  @@index([gameId])
}
